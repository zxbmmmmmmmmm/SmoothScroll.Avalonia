<Window
    x:Class="SmoothScroll.Avalonia.Sample.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="clr-namespace:SmoothScroll.Avalonia.Sample.Views.Pages"
    xmlns:views="using:SmoothScroll.Avalonia.Sample.Views"
    xmlns:vm="using:SmoothScroll.Avalonia.Sample.ViewModels"
    Title="SmoothScroll.Avalonia"
    d:DesignHeight="450"
    d:DesignWidth="800"
    Icon="/Assets/avalonia-logo.ico"
    mc:Ignorable="d">
    <TabControl>
        <TabItem Header="Zooming">
            <views:MainView />
        </TabItem>
        <TabItem Header="List">
            <pages:ListPage />
        </TabItem>
        <TabItem Header="Test" />
    </TabControl>
</Window>
