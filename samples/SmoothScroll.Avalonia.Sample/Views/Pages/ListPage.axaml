<ContentPage
    x:Class="SmoothScroll.Avalonia.Sample.Views.Pages.ListPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SmoothScroll.Avalonia.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:SmoothScroll.Avalonia.Sample.ViewModels"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="viewModels:ListViewModel"
    mc:Ignorable="d">
    <Design.DataContext>
        <viewModels:ListViewModel />
    </Design.DataContext>
    <ListBox SelectionMode="Multiple" ItemsSource="{Binding Items}">
        <ListBox.ItemTemplate>
            <DataTemplate x:DataType="x:Int32">
                <TextBlock Margin="8" Text="{CompiledBinding}" />
            </DataTemplate>
        </ListBox.ItemTemplate>
    </ListBox>

</ContentPage>
