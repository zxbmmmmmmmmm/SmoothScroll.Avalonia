<UserControl
    x:Class="SmoothScroll.Avalonia.Sample.Views.Pages.ZoomPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:SmoothScroll.Avalonia.Controls;assembly=SmoothScroll.Avalonia.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Panel>
        <controls:ScrollView
            x:Name="ScrollView"
            HorizontalContentAlignment="Stretch"
            VerticalContentAlignment="Stretch"
            HorizontalScrollBarVisibility="Hidden"
            IsZoomEnabled="True"
            VerticalScrollBarVisibility="Hidden">
            <Image Source="avares://SmoothScroll.Avalonia.Sample/Assets/Images/4074.bmp" Stretch="UniformToFill" />
        </controls:ScrollView>
        <Grid
            Margin="10"
            HorizontalAlignment="Left"
            VerticalAlignment="Top">
            <TextBlock FontSize="16" Text="{Binding #ScrollView.ZoomFactor, Mode=OneWay, StringFormat=Zoom: {0:F1}x}" />
        </Grid>
    </Panel>
</UserControl>
