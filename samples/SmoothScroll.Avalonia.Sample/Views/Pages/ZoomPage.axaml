<ContentPage
    x:Class="SmoothScroll.Avalonia.Sample.Views.Pages.ZoomPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:SmoothScroll.Avalonia.Controls;assembly=SmoothScroll.Avalonia.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Panel>
        <controls:ScrollView
            x:Name="ScrollView"
            HorizontalContentAlignment="Stretch"
            VerticalContentAlignment="Stretch"
            HorizontalScrollBarVisibility="Hidden"
            IsZoomEnabled="True"
            VerticalScrollBarVisibility="Hidden">
            <Image Source="avares://SmoothScroll.Avalonia.Sample/Assets/Images/4074.bmp" Stretch="UniformToFill" />
        </controls:ScrollView>
        <Border
            Margin="24"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
            ClipToBounds="True"
            CornerRadius="128">
            <Border.Styles>
                <Style Selector="Button">
                    <Setter Property="Background" Value="Transparent" />
                </Style>
            </Border.Styles>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button
                    x:Name="ZoomInButton"
                    Padding="12,4,8,4"
                    Click="ZoomInButton_Click"
                    Content="+"
                    CornerRadius="0"
                    FontSize="20" />
                <TextBlock
                    Width="56"
                    TextAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="16"
                    Text="{Binding #ScrollView.ZoomFactor, Mode=OneWay, StringFormat={}{0:P1}}" />
                <Button
                    x:Name="ZoomOutButton"
                    Padding="8,4,12,4"
                    Click="ZoomOutButton_Click"
                    Content="-"
                    CornerRadius="0"
                    FontSize="20" />
            </StackPanel>
        </Border>
    </Panel>
</ContentPage>
