<ContentPage
    x:Class="SmoothScroll.Avalonia.Sample.Views.Pages.TextboxPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:SmoothScroll.Avalonia.Sample.ViewModels"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="viewModels:TextBoxViewModel"
    mc:Ignorable="d">
    <Design.DataContext>
        <viewModels:TextBoxViewModel />
    </Design.DataContext>
    <TextBox Text="{Binding Text }" TextWrapping="Wrap"/>
</ContentPage>
