<UserControl
    x:Class="SmoothScroll.Avalonia.Sample.Views.MainView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:SmoothScroll.Avalonia.Controls;assembly=SmoothScroll.Avalonia.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="clr-namespace:SmoothScroll.Avalonia.Sample.Views.Pages"
    xmlns:presenters="clr-namespace:Avalonia.Controls.Presenters;assembly=SmoothScroll.Avalonia.Controls"
    xmlns:vm="using:SmoothScroll.Avalonia.Sample.ViewModels"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <TabControl>
        <TabItem Header="Zooming">
            <pages:ZoomPage />
        </TabItem>
        <TabItem Header="List">
            <pages:ListPage />
        </TabItem>
        <TabItem Header="TextBox">
            <pages:TextboxPage />
        </TabItem>
        <TabItem Header="Chaining">
            <pages:ChainingPage />
        </TabItem>
        <TabItem Header="Interaction">
            <pages:InteractionTrackerPage />
        </TabItem>
    </TabControl>
</UserControl>
