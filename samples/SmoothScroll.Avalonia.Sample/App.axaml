<Application
    x:Class="SmoothScroll.Avalonia.Sample.App"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SmoothScroll.Avalonia.Sample"
    xmlns:smoothScroll="using:SmoothScroll.Avalonia.Controls"
    RequestedThemeVariant="Default">
    <!--  "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options.  -->

    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
        <smoothScroll:ScrollViewDefaultTheme />
        <smoothScroll:ScrollViewerSmoothTheme />
    </Application.Styles>
</Application>
